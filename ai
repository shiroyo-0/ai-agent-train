#!/usr/bin/env python3
"""AI Agent CLI - connects to local Qwen model server."""

import sys
import json
import httpx

API = "http://localhost:8080"


def chat(message: str) -> str:
    r = httpx.post(f"{API}/chat", json={"message": message}, timeout=120)
    return r.json()["response"]


def status():
    r = httpx.get(f"{API}/training/status", timeout=5)
    d = r.json()
    if d.get("cycles"):
        l = d["latest"]
        print(f"🎓 Training: {d['cycles']} cycles | Last: {l['examples']} examples, score {l['avg_score']}/10, {l['high_quality']} HQ | {l['elapsed_seconds']}s")
    else:
        print("No training cycles yet.")


def health():
    r = httpx.get(f"{API}/health", timeout=5)
    d = r.json()
    print(f"✅ Status: {d['status']} | Model: {d['model']}")
    if d.get("training", {}).get("cycles"):
        print(f"🎓 Cycles: {d['training']['cycles']}")


def interactive():
    print("""
╔══════════════════════════════════════════════════════╗
║  🤖 AI Agent CLI (Qwen 0.5B Local)                  ║
╠══════════════════════════════════════════════════════╣
║  Commands: status, health, clear, exit               ║
║  Or just type your question                          ║
╚══════════════════════════════════════════════════════╝
""")
    while True:
        try:
            msg = input("\033[36m❯\033[0m ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\n👋 Bye!")
            break
        if not msg:
            continue
        if msg == "exit":
            break
        if msg == "status":
            status()
            continue
        if msg == "health":
            health()
            continue
        if msg == "clear":
            print("\033[2J\033[H")
            continue
        print(f"\n\033[32m🤖\033[0m {chat(msg)}\n")


def main():
    if len(sys.argv) < 2:
        interactive()
        return

    cmd = sys.argv[1]
    if cmd == "status":
        status()
    elif cmd == "health":
        health()
    elif cmd == "chat":
        if len(sys.argv) > 2:
            print(f"🤖 {chat(' '.join(sys.argv[2:]))}")
        else:
            interactive()
    elif cmd in ("-h", "--help", "help"):
        print("""🤖 AI Agent CLI

Usage:
  ai                     Interactive chat
  ai chat <message>      One-shot chat
  ai status              Training progress
  ai health              Server health
  ai help                This help

Server: http://165.22.102.81:8080
Web UI: http://165.22.102.81:8080 (browser)
""")
    else:
        # Treat as chat message
        print(f"\n🤖 {chat(' '.join(sys.argv[1:]))}\n")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""AI Agent CLI - connects to local Qwen model."""

import sys
import json
import httpx

API = "http://localhost:8080"

def chat(message: str) -> str:
    r = httpx.post(f"{API}/chat", json={"message": message}, timeout=120)
    return r.json()["response"]

def status():
    r = httpx.get(f"{API}/training/status", timeout=5)
    d = r.json()
    if d.get("cycles"):
        l = d["latest"]
        print(f"🎓 Training: {d['cycles']} cycles | Last: {l['examples']} examples, score {l['avg_score']}/10, {l['high_quality']} HQ")
    else:
        print("No training cycles yet.")

def main():
    if len(sys.argv) > 1:
        cmd = sys.argv[1]
        if cmd == "status":
            status()
            return
        # One-shot message
        msg = " ".join(sys.argv[1:])
        print(f"\n🤖 {chat(msg)}\n")
        return

    # Interactive mode
    print("🤖 AI Agent (Qwen 0.5B) — type 'exit' to quit, 'status' for training info\n")
    while True:
        try:
            msg = input("❯ ").strip()
        except (EOFError, KeyboardInterrupt):
            break
        if not msg:
            continue
        if msg == "exit":
            break
        if msg == "status":
            status()
            continue
        print(f"\n🤖 {chat(msg)}\n")

if __name__ == "__main__":
    main()

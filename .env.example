# AI Agent Environment Configuration
# Copy to .env and fill in values

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Local Models
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8000

# Default Model
AI_AGENT_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
AI_AGENT_FALLBACK_MODEL=ollama/llama3

# Database
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/ai_agent
REDIS_URL=redis://localhost:6379/0

# Vector Store
CHROMA_HOST=localhost
CHROMA_PORT=8100
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Agent Settings
AI_AGENT_MAX_ITERATIONS=50
AI_AGENT_MAX_TOKENS=8192
AI_AGENT_TEMPERATURE=0.1
AI_AGENT_TIMEOUT=300

# Security
AI_AGENT_SANDBOX_ENABLED=true
AI_AGENT_ALLOW_SHELL=true
AI_AGENT_ALLOW_NETWORK=true
AI_AGENT_AUDIT_LOG=true

# Paths
AI_AGENT_DATA_DIR=~/.ai-agent
AI_AGENT_LOG_LEVEL=INFO
